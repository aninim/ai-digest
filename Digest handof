<script>
const PASSWORD = "dads42digest";

function checkPw() {
  const val = document.getElementById('pw').value;
  if (val === PASSWORD) {
    localStorage.setItem('digest_auth', '1');
    document.getElementById('gate').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    loadDigest();
  } else {
    document.getElementById('pw-err').style.display = 'block';
    document.getElementById('pw').value = '';
  }
}

if (localStorage.getItem('digest_auth') === '1') {
  document.getElementById('gate').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  loadDigest();
}

async function loadDigest() {
  try {
    const res = await fetch('./data.json?v=' + Date.now());
    const data = await res.json();
    renderDigest(data);
  } catch(e) {
    document.getElementById('loading').textContent = 'NO DATA YET. RUN AGENT FIRST.';
  }
}

function renderDigest(d) {
  document.getElementById('loading').style.display = 'none';
  document.getElementById('content').style.display = 'block';
  document.getElementById('top-story-text').textContent = d.top_story || 'No top story today.';
  document.getElementById('ts').innerHTML = `DATE<br>${d.date}<br><br>UPDATED<br>${new Date().toLocaleTimeString()}`;

  const sections = [
    { key: 'tools', label: '🔧 TOOLS', render: renderTools },
    { key: 'hacks', label: '⚡ HACKS', render: renderHacks },
    { key: 'use_cases', label: '💡 USE CASES', render: renderUseCases },
    { key: 'big_moves', label: '🚀 BIG MOVES', render: renderBigMoves },
    { key: 'deprecated', label: '❌ DEPRECATED', render: renderDeprecated },
  ];

  const grid = document.getElementById('grid');
  sections.forEach((s, i) => {
    const items = d[s.key] || [];
    const card = document.createElement('div');
    card.className = 'card';
    const isOpen = i < 2;
    card.innerHTML = `
      <div class="card-header ${isOpen ? 'open' : ''}" onclick="toggleCard(this)">
        <span class="card-title">${s.label}</span>
        <span style="display:flex;gap:0.5rem;align-items:center">
          <span class="card-count">${items.length}</span>
          <span class="chevron ${isOpen ? 'open' : ''}">▾</span>
        </span>
      </div>
      <div class="card-body ${isOpen ? 'open' : ''}">${items.length ? s.render(items) : '<p class="empty">nothing notable today</p>'}</div>
    `;
    grid.appendChild(card);
  });

  buildTicker(d);
  lastDate = d.date;
}

function toggleCard(header) {
  header.classList.toggle('open');
  header.querySelector('.chevron').classList.toggle('open');
  header.nextElementSibling.classList.toggle('open');
}

function renderTools(items) {
  return items.map(i => `
    <div class="item">
      <div class="item-title">${i.name}</div>
      <div class="item-desc">${i.summary}</div>
      <div class="item-meta">
        ${i.relevance ? `<span class="tag accent">${i.relevance}</span>` : ''}
      </div>
      ${i.url ? `<a class="item-link" href="${i.url}" target="_blank">→ ${i.url}</a>` : ''}
    </div>`).join('');
}

function renderHacks(items) {
  return items.map(i => `
    <div class="item">
      <div class="item-title">${i.title}</div>
      <div class="item-desc">${i.description}</div>
      <div class="item-meta"><span class="tag">${i.source || ''}</span></div>
    </div>`).join('');
}

function renderUseCases(items) {
  return items.map(i => `
    <div class="item">
      <div class="item-title">${i.title}</div>
      <div class="item-desc">${i.description}</div>
      <div class="item-meta">
        ${i.applicable_to ? `<span class="tag accent2">${i.applicable_to}</span>` : ''}
      </div>
    </div>`).join('');
}

function renderBigMoves(items) {
  return items.map(i => `
    <div class="item">
      <div class="item-title">${i.who}</div>
      <div class="item-desc">${i.what}</div>
      <div class="item-meta"><span class="tag">${i.why_it_matters || ''}</span></div>
    </div>`).join('');
}

function renderDeprecated(items) {
  return items.map(i => `
    <div class="item">
      <div class="item-title" style="text-decoration:line-through;color:var(--muted)">${i.what}</div>
      <div class="item-desc">${i.note}</div>
    </div>`).join('');
}

// TICKER
function buildTicker(d) {
  const items = [];
  (d.big_moves || []).forEach(i => items.push({ cat: 'MOVE', text: `${i.who} — ${i.what}` }));
  (d.tools || []).forEach(i => items.push({ cat: 'TOOL', text: `${i.name}: ${i.summary}` }));
  (d.hacks || []).forEach(i => items.push({ cat: 'HACK', text: i.title + ' — ' + i.description }));
  (d.use_cases || []).forEach(i => items.push({ cat: 'USE', text: i.title + ': ' + i.description }));
  (d.deprecated || []).forEach(i => items.push({ cat: 'DEAD', text: i.what + ' — ' + i.note }));
  if (!items.length) return;

  // Double the items so seamless loop works
  const all = [...items, ...items];
  const track = document.getElementById('ticker-track');
  track.innerHTML = all.map(i =>
    `<span class="ticker-item"><span class="ticker-cat">[${i.cat}]</span>${i.text}<span class="ticker-sep">◆</span></span>`
  ).join('');
  document.getElementById('ticker-wrap').style.display = 'flex';

  // Adjust animation speed to content length
  const totalChars = items.reduce((s, i) => s + i.text.length, 0);
  const duration = Math.max(40, totalChars * 0.18);
  track.style.animationDuration = duration + 's';
}

// Re-fetch data.json every 5 minutes to catch fresh pushes
let lastDate = null;
async function pollDigest() {
  try {
    const res = await fetch('./data.json?v=' + Date.now());
    const data = await res.json();
    if (data.date !== lastDate) {
      lastDate = data.date;
      buildTicker(data);
    }
  } catch(e) {}
}
setInterval(pollDigest, 5 * 60 * 1000);
</script>
</body>
</html>
